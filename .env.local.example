## Next.js (frontend) environment variables
## Copy to `.env.local` and fill values.

# Required: OpenAI-compatible API key (kept on the server via Next.js route handlers)
OPENAI_API_KEY=

# Optional
OPENAI_MODEL=gpt-4o-mini
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MAX_TOKENS=900
OPENAI_PROMPT_TOKEN_BUDGET=8000
OPENAI_MESSAGE_CHAR_LIMIT=6000
AI_REQUEST_TIMEOUT_MS=90000

# Aliases (optional): you can use these instead of OPENAI_* if you prefer
AI_API_KEY=
AI_MODEL=
AI_BASE_URL=

# Provider-specific aliases (optional)
GROQ_API_KEY=
OPENROUTER_API_KEY=
OPENROUTER_MODEL=
OPENROUTER_HTTP_REFERER=http://localhost:3000
OPENROUTER_APP_TITLE=AutoSRS.ai

# Back-compat aliases (optional)
OPENROUTER_REFERRER=http://localhost:3000
OPENROUTER_APP_NAME=AutoSRS.ai

# If you are using OpenRouter, set these so the app routes requests to OpenRouter:
# OPENAI_BASE_URL=https://openrouter.ai/api/v1
# OPENAI_MODEL=<your OpenRouter model id or use OPENROUTER_MODEL>

# Gemini (Google AI Studio) - set AI_PROVIDER=gemini to use Gemini instead of OpenAI-compatible providers.
AI_PROVIDER=
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
# Optional override:
# GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta

# Force OpenAI-compatible providers even if GEMINI_API_KEY is set:
# AI_PROVIDER=openai-compatible

# Groq (OpenAI-compatible)
# AI_PROVIDER=groq
# GROQ_API_KEY=...
# OPENAI_BASE_URL=https://api.groq.com/openai/v1
# OPENAI_MODEL=llama-3.3-70b-versatile

# Local Ollama (free, no cloud rate limits; slower on CPU so keep outputs small)
# OPENAI_BASE_URL=http://localhost:11434/v1
# OPENAI_API_KEY=local
# OPENAI_MODEL=llama3.2:1b
# OPENAI_MAX_TOKENS=320
# OPENAI_PROMPT_TOKEN_BUDGET=3800
# OPENAI_MESSAGE_CHAR_LIMIT=2600
# AI_REQUEST_TIMEOUT_MS=60000
# OLLAMA_KEEP_ALIVE=30m

# Optional (PDF diagrams): Mermaid -> PNG via Kroki
KROKI_BASE_URL=https://kroki.io
