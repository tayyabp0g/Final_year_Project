# Copy this file to .env and fill in your values
# cp .env.example .env

# ── LLM ──────────────────────────────────────────────────────────────────────
# Your OpenRouter API key (https://openrouter.ai/keys)
OPENROUTER_API_KEY=your-openrouter-api-key-here

# OpenRouter model slug (e.g. openai/gpt-4o, anthropic/claude-3.5-sonnet)
MODEL_NAME=openai/gpt-4o-mini

# Lightweight model used by the message guardrail classifier
GUARDRAIL_MODEL_NAME=openai/gpt-4o-mini

# ── Database ─────────────────────────────────────────────────────────────────
# Must match docker-compose.yml values
DB_URI=postgresql+psycopg://srs_user:srs_pass@localhost:5432/srs_db

# ── Vector Store ─────────────────────────────────────────────────────────────
# Directory where ChromaDB stores its files
CHROMA_PATH=.chroma

# ── App ───────────────────────────────────────────────────────────────────────
APP_HOST=0.0.0.0
APP_PORT=8000
APP_RELOAD=true

# ── DOCX Export Metadata ─────────────────────────────────────────────────────
DOCX_TITLE=SRS
DOCX_AUTHOR=Your Name or Team
DOCX_COMMENT=Generated by AI SRS Generator
